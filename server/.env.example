# 服务端配置
# client服务端口号
CLIENT_PORT=3001
# admin服务端口号
ADMIN_PORT=3002

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shopping_mall
DB_USER=root
DB_PASSWORD=your_password

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 环境配置
# NODE_ENV=development

# 编译环境配置
COMPILE_ENV=NONE

# 日志配置
LOG_LEVEL=info
