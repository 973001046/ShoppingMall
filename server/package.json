{
  "name": "shopping-mall-server",
  "version": "1.0.0",
  "description": "Shopping Mall Backend API Server - Koa.js + MySQL",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "dev:client": "cross-env SERVICE=client NODE_ENV=development nodemon src/app.js",
    "dev:admin": "cross-env SERVICE=admin NODE_ENV=development nodemon src/app.js",
    "start:client": "cross-env SERVICE=client NODE_ENV=production node src/app.js",
    "start:admin": "cross-env SERVICE=admin NODE_ENV=production node src/app.js",
    "start:all": "npm run start:client & npm run start:admin",
    "init:db": "node src/scripts/init-db.js"
  },
  "keywords": ["koa", "mysql", "api", "shopping"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "koa": "^2.14.2",
    "koa-router": "^12.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-cors": "^0.0.16",
    "koa-logger": "^3.2.1",
    "koa-jwt": "^4.0.4",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "koa-static": "^5.0.0",
    "koa-mount": "^4.0.0",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "cross-env": "^7.0.3"
  }
}
